{
  "name": "hermesagent-download",
  "type": "module",
  "version": "0.1.0",
  "description": "Hermes Agent 中文社群知識庫 — 共筆、開源、自動進化",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "postinstall": "node scripts/core/sync.mjs",
    "sync": "node scripts/core/sync.mjs",
    "dev": "npm run sync && astro dev",
    "prebuild": "npm run sync",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "article-health": "node scripts/tools/article-health.mjs",
    "article-health:strict": "node scripts/tools/article-health.mjs --profile=release-pr",
    "check-links": "node scripts/tools/check-links.mjs",
    "format:check": "prettier --check .",
    "format:write": "prettier --write .",
    "prepare": "husky"
  },
  "dependencies": {
    "@astrojs/rss": "^4.0.11",
    "@astrojs/sitemap": "^3.2.1",
    "@tailwindcss/vite": "^4.0.0",
    "astro": "^5.7.0",
    "gray-matter": "^4.0.3",
    "rehype-external-links": "^3.0.0",
    "tailwindcss": "^4.0.0"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^17.1.1",
    "prettier": "^3.5.0",
    "prettier-plugin-astro": "^0.14.1"
  }
}

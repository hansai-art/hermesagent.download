---
import { CATEGORIES } from '../config/categories.mjs';
import Search from './Search.astro';

// 導覽只放高頻分類,完整清單在首頁與 footer
const NAV_SLUGS = ['install', 'config', 'skills', 'troubleshoot', 'releases'];
const nav = CATEGORIES.filter((c) => NAV_SLUGS.includes(c.slug));
---

<header
  class="sticky top-0 z-10 border-b backdrop-blur"
  style="border-color: var(--border); background: color-mix(in srgb, var(--bg) 85%, transparent)"
>
  <div class="max-w-5xl mx-auto px-5 h-14 flex items-center gap-6">
    <a href="/" class="font-bold tracking-tight text-lg" style="color: var(--text)">
      hermes<span style="color: var(--accent)">agent</span>.download
    </a>
    <nav class="hidden md:flex gap-4 text-sm" style="color: var(--text-dim)">
      {
        nav.map((c) => (
          <a href={`/${c.slug}/`} class="hover:opacity-100 transition-opacity" style="color: var(--text-dim)">
            {c.name}
          </a>
        ))
      }
      <a href="/contribute/" class="transition-opacity" style="color: var(--accent)">✋ 我想貢獻</a>
    </nav>
    <div class="flex-1"></div>
    <Search />
    <a
      href="https://github.com/hansai-art/hermesagent.download"
      class="text-sm"
      style="color: var(--text-dim)"
      target="_blank"
      rel="noopener noreferrer">GitHub ↗</a
    >
  </div>
</header>
